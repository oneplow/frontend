            <div className="flex items-baseline gap-1.5 mb-4">
              <span className="text-3xl font-bold text-slate-900 leading-none tracking-tight">{aggregated.requests > 0 ? `${aggregated.avgLatency.toFixed(1)}s` : \'—\'}</span>
              <span className="text-[11px] font-medium text-slate-400">of {tokenLimitStr} tokens</span>
